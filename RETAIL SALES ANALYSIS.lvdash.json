{
  "datasets": [
    {
      "name": "e6bb8390",
      "displayName": "Customer Insights by Date and Product Category",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT COUNT(DISTINCT `Customer ID`) AS unique_customers, -- Counts the number of unique customers (removes duplicates so each customer is counted once)\n",
        "\n",
        "       Date, -- The actual transaction date for each record\n",
        "\n",
        "      YEAR(Date) AS trans_year, -- Extracts the year from the Date column (e.g., 2026)\n",
        "\n",
        "      MONTH(Date) AS trans_month, -- Extracts the numeric month (1 = January, 12 = December)\n",
        "      MONTHNAME(Date) AS trans_month_name,  -- Extracts the full month name (e.g., \"January\")\n",
        "\n",
        "\n",
        "      DAY(Date) AS trans_day, --- Extracts the day of the month (e.g., 15)\n",
        "      DAYNAME(Date) AS trans_day_name, -- Extracts the weekday name (e.g., \"Monday\")\n",
        "\n",
        "       `Product Category`, -- Identifies the category of the product (e.g., Beauty, Clothing, Electronics)\n",
        "\n",
        "      SUM(`Total Amount`) AS revenue, -- Calculates total revenue by summing all transaction amounts\n",
        "      SUM(Quantity) AS Number_of_units_sold --  Calculates total units sold by summing all transaction quantities\n",
        "\n",
        "FROM retail.sales.dataset -- This is the source table containing all sales data\n",
        "GROUP BY ALL; -- Grouping my data based on all the columns that are not aggregated in my Select Statements\n",
        "\n",
        "\n",
        "\n",
        "\n"
      ]
    },
    {
      "name": "09d9ab62",
      "displayName": "Orders and Customers",
      "queryLines": [
        "SELECT\n",
        "  o_orderdate,\n",
        "  o_custkey\n",
        "FROM\n",
        "  `samples`.`tpch`.`orders`"
      ]
    }
  ],
